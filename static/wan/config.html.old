<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>WAN - Configuración</title>
<style>
html, body { margin: 0; font-family: Arial, sans-serif; padding: 10px; background-color: #eef3f8; }
button { margin: 5px; padding: 8px 12px; cursor: pointer; border: 1px solid #ccc; background-color: #eee; }
button.selected { background-color: #3399ff; color: white; border-color: #007acc; }
#manualFields { display: none; margin-top: 10px; }
label { display: block; margin: 5px 0; }
input { padding: 4px; margin-left: 5px; }
pre {
    white-space: pre-wrap;
    word-wrap: break-word;
    font-size: 14px;
    background: #f8f8f8;
    padding: 10px;
    border: 1px solid #ddd;
}
</style>
</head>
<body>

<h3>Configuración WAN</h3>

<pre id="output">Rellena los campos y guarda la configuración.</pre>

<div>
    <button id="btnDHCP" onclick="setMode('dhcp')">DHCP</button>
    <button id="btnManual" onclick="setMode('manual')">Manual</button>
</div>

<form onsubmit="submitConfig(event)">
    <label>Interfaz: <input type="text" id="interface" required></label>

    <div id="manualFields">
        <label>IP: <input type="text" id="ip"></label>
        <label>Máscara: <input type="text" id="mask"></label>
        <label>Gateway: <input type="text" id="gateway"></label>
        <label>DNS: <input type="text" id="dns"></label>
    </div>

    <input type="hidden" id="mode">
    <button type="submit">Guardar Configuración</button>
</form>

<script>
function setMode(m) {
    document.getElementById("mode").value = m;
    document.getElementById("manualFields").style.display = (m === "manual") ? "block" : "none";

    btnDHCP.classList.toggle("selected", m === "dhcp");
    btnManual.classList.toggle("selected", m === "manual");
}

async function submitConfig(e) {
    e.preventDefault();

    const params = new URLSearchParams();
    params.append("action", "config");
    params.append("mode", mode.value);
    params.append("interface", interface.value);

    if (mode.value === "manual") {
        params.append("ip", ip.value);
        params.append("mask", mask.value);
        params.append("gateway", gateway.value);
        params.append("dns", dns.value);
    }

    const output = document.getElementById("output");
    output.textContent = "Guardando configuración...\n";

    try {
        const resp = await fetch(`/run/wan.py?${params}`);
        const text = await resp.text();
        output.textContent += text;
    } catch (e) {
        output.textContent += "Error: " + e;
    }
}
</script>

</body>
</html>
